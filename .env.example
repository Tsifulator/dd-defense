# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — it must never be committed.
# Rotate ANY key that has ever been pasted into chat/email or committed to git.

ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Web app (optional) ---
# Set a password to require login on the web app. If unset, the app is OPEN
# (fine for local-only use; REQUIRED before deploying or sharing a link).
# DD_APP_PASSWORD=choose-a-strong-password

# Stable secret for signing session cookies. If unset, a random per-process key
# is used (sessions reset on restart). Set this in any real deployment.
# DD_SECRET_KEY=generate-a-long-random-string

# Set to 1 when served over HTTPS so the session cookie is marked Secure.
# DD_COOKIE_SECURE=1

# Where the case database lives (default: data/cases.db).
# DD_DB_PATH=data/cases.db
