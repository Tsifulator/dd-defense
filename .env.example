# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — it must never be committed.
# Rotate ANY key that has ever been pasted into chat/email or committed to git.

ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Web app (optional) ---
# Set a password to require login on the web app. If unset, the app is OPEN
# (fine for local-only use; REQUIRED before deploying or sharing a link).
# DD_APP_PASSWORD=choose-a-strong-password

# Stable secret for signing session cookies. If unset, a random per-process key
# is used (sessions reset on restart). Set this in any real deployment.
# DD_SECRET_KEY=generate-a-long-random-string

# Set to 1 when served over HTTPS so the session cookie is marked Secure.
# DD_COOKIE_SECURE=1

# Where the case database lives (default: data/cases.db).
# DD_DB_PATH=data/cases.db

# --- Airtable operations base (optional — outreach queue / leads / case sync) ---
# See AIRTABLE_SETUP.md for the 5-minute setup. Token needs data.records:read+write
# and (for airtable-setup) schema.bases:read+write.
# AIRTABLE_API_KEY=pat-your-token
# AIRTABLE_BASE_ID=app-your-base-id
# AIRTABLE_TABLE_PROSPECTS=Prospects   # override table names only if you renamed them
# AIRTABLE_TABLE_LEADS=Leads
# AIRTABLE_TABLE_CASES=Cases

# --- Autonomous invoice intake (optional — the email inbox bot) ---
# See INBOX_SETUP.md. Gmail needs an APP PASSWORD (not your normal password).
# DD_IMAP_HOST=imap.gmail.com
# DD_IMAP_USER=dnd.invoices@gmail.com
# DD_IMAP_PASSWORD=your-16-char-app-password
# DD_IMAP_FOLDER=INBOX
